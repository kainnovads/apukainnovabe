# App
APP_NAME=adonis-app
PORT=3333
HOST=0.0.0.0
NODE_ENV=development

# Basis URL untuk URL file yang di-upload ke public/uploads
APP_URL=http://localhost:3333

LOG_LEVEL=info

# App Key (wajib, auto-generate via node ace generate:key)
APP_KEY=

# Database
DB_CONNECTION=pgsql
DB_HOST=127.0.0.1
DB_PORT=5432
DB_USER=postgres
DB_PASSWORD=
DB_DATABASE=adoniserp2

# Auth
DRIVE_DISK=local
SESSION_DRIVER=cookie

# Mail (optional, kalau ada fitur kirim email)
SMTP_HOST=sandbox.smtp.mailtrap.io
SMTP_PORT=2525
SMTP_USERNAME=
SMTP_PASSWORD=
MAIL_FROM_ADDRESS=
SMTP_FROM_NAME="Dummy Mailer"

# Penyimpanan: hanya local (public/uploads)
STORAGE_DRIVER=local

# CORS
CORS_ENABLED=true

CACHE_VIEWS=false
MAILGUN_API_KEY=
MAILGUN_DOMAIN=
SPARKPOST_API_KEY=
